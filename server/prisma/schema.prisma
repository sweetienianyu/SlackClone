generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  username    String   @unique
  displayName String
  password    String
  avatarUrl   String?
  status      String   @default("online") // online, away, busy, offline
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspaceMembers WorkspaceMember[]
  channelMembers   ChannelMember[]
  messages         Message[]
  reactions        Reaction[]
  ownedWorkspaces  Workspace[]  @relation("WorkspaceOwner")
  documents        Document[]
}

model Workspace {
  id        String   @id @default(uuid())
  name      String
  iconUrl   String?
  inviteCode String? @unique
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner   User              @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  members WorkspaceMember[]
  channels Channel[]
  channelGroups ChannelGroup[]
  documents Document[]

  @@map("workspaces")
}

model WorkspaceMember {
  id          String   @id @default(uuid())
  userId      String
  workspaceId String
  role        String   @default("member") // admin, member
  joinedAt    DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@map("workspace_members")
}

model Channel {
  id          String   @id @default(uuid())
  workspaceId String
  name        String
  type        String   @default("public") // public, private, dm
  topic       String?
  description String?
  groupId     String?
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  group     ChannelGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  members   ChannelMember[]
  messages  Message[]
  pinnedMessages PinnedMessage[]
  documents Document[]

  @@unique([workspaceId, name])
  @@map("channels")
}

model ChannelGroup {
  id          String   @id @default(uuid())
  workspaceId String
  name        String
  sort        Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  channels  Channel[]

  @@map("channel_groups")
}

model ChannelMember {
  id              String    @id @default(uuid())
  channelId       String
  userId          String
  role            String    @default("member")
  lastReadAt      DateTime?
  muted           Boolean   @default(false)
  mutedUntil      DateTime?
  notifyPreference String   @default("all") // all, mentions, none
  pinned          Boolean   @default(false)
  joinedAt        DateTime  @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([channelId, userId])
  @@map("channel_members")
}

model PinnedMessage {
  id        String   @id @default(uuid())
  channelId String
  messageId String
  pinnedBy  String
  createdAt DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([channelId, messageId])
  @@map("pinned_messages")
}

model Message {
  id        String    @id @default(uuid())
  channelId String
  userId    String
  content   String
  parentId  String?
  type      String    @default("text") // text, file, system
  fileUrl   String?
  fileName  String?
  fileSize  Int?
  fileType  String?
  editedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  channel  Channel    @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user     User       @relation(fields: [userId], references: [id])
  parent   Message?   @relation("MessageReplies", fields: [parentId], references: [id])
  replies  Message[]  @relation("MessageReplies")
  reactions Reaction[]
  pinnedIn PinnedMessage[]

  @@map("messages")
}

model Reaction {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([messageId, userId, emoji])
  @@map("reactions")
}

model Document {
  id          String   @id @default(uuid())
  workspaceId String
  channelId   String?
  title       String
  content     String   @default("")
  template    String   @default("blank") // blank, meeting, plan, retro
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  channel   Channel?  @relation(fields: [channelId], references: [id], onDelete: SetNull)
  creator   User      @relation(fields: [createdBy], references: [id])

  @@map("documents")
}
